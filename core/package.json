{
  "name": "@headless-toast/core",
  "version": "0.0.3",
  "description": "Framework-agnostic headless toast state machine with zero DOM dependencies",
  "type": "module",
  "homepage": "https://cjvnjde.github.io/headless-toast",
  "bugs": {
    "url": "https://github.com/cjvnjde/headless-toast/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cjvnjde/headless-toast.git",
    "directory": "core"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "toast",
    "notifications",
    "headless",
    "typescript",
    "framework-agnostic",
    "state-machine",
    "core"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Vitalij Nykyforenko <vitalij.nykyforenko@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
